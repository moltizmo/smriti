    "semantic-search",
    "claude-code",
    "cursor",
    "kiro"
  ],
  "author": "Bharadwaz Kari <moltizmo@zohomail.com> (https://bharadwazkari.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/moltizmo/smriti.git"
  },
  "homepage": "https://github.com/moltizmo/smriti#readme",
  "bugs": {
    "url": "https://github.com/moltizmo/smriti/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
